package Assignment3.Module6;
//Find the missing number from an array containing numbers from 1 to n.
public class MissingNumber {
    public static void main(String[] args) {
        int[] arr = {1, 2, 4, 5};
        int n = 5;
        int sum = n * (n + 1) / 2;
        int arrSum = 0;
        for (int num : arr)
            arrSum += num;
        System.out.println(sum - arrSum);
    }
}
