package Assignment3.Module7;
//Find first and last occurrence of an element using Binary Search.
public class BinarySearchRecursive {
    static int search(int arr[], int low, int high, int key) {
        if (low > high)
            return -1;
        int mid = (low + high) / 2;
        if (arr[mid] == key)
            return mid;
        if (arr[mid] > key)
            return search(arr, low, mid - 1, key);
        return search(arr, mid + 1, high, key);
    }
    public static void main(String[] args) {
        int[] arr = {1, 3, 5, 7, 9};
        int key = 7;
        int result = search(arr, 0, arr.length - 1, key);
        System.out.println("Position: " + result);
    }
}
